# octopOS Environment Configuration
# EC2 Deployment için environment değişkenleri

# =============================================================================
# AWS Configuration
# =============================================================================
# AWS Region - Nova model'lerin bulunduğu region
AWS_REGION=us-east-1

# AWS Profile (local machine profile veya EC2 IAM role)
AWS_PROFILE=default

# AWS Access Key (local development için - EC2'de IAM role kullanılır)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Agent Configuration
# =============================================================================
# Agent adı
AGENT_NAME=octo

# Agent kişilik: friendly, professional, technical
AGENT_PERSONA=technical

# Agent dili (tr, en)
AGENT_LANGUAGE=tr

# Nova Model IDs
# model_nova_lite=amazon.nova-lite-v1:0
# model_nova_micro=amazon.nova-micro-v1:0
# model_nova_pro=amazon.nova-pro-v1:0

# =============================================================================
# User Configuration
# =============================================================================
# Kullanıcı adı
USER_NAME=admin

# Kullanıcı timezone
USER_TIMEZONE=Europe/Istanbul

# Workspace path (container içinde)
USER_WORKSPACE_PATH=/workspace

# =============================================================================
# Paths
# =============================================================================
# LanceDB vector database path
LANCEDB_PATH=/data/lancedb

# SQLite task database path
TASK_DB_PATH=/data/tasks.db

# =============================================================================
# Security
# =============================================================================
# Otomatik onay (düşük riskli işlemler için)
AUTO_APPROVE_SAFE_OPERATIONS=false

# Kod üretimi için onay gereksinimi
REQUIRE_APPROVAL_FOR_CODE=true

# =============================================================================
# Logging
# =============================================================================
# Log seviyesi: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log destination: cloudwatch, file, stdout
LOG_DESTINATION=stdout

# =============================================================================
# Web Configuration
# =============================================================================
# Fiyat karşılaştırma için varsayılan siteler
DEFAULT_COMPARISON_SITES=["amazon.com", "trendyol.com", "hepsiburada.com"]

# =============================================================================
# Debug
# =============================================================================
DEBUG=false

# Mock AWS (test için)
MOCK_AWS=false