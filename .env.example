# octopOS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# AWS Configuration
# ============================================================================

# AWS Region for Bedrock and other services
AWS_REGION=us-east-1

# Option 1: AWS Profile (recommended for local development)
AWS_PROFILE=default

# Option 2: Direct credentials (use with caution)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_SESSION_TOKEN=your_session_token_here  # Optional, for temporary credentials

# Option 3: STS Role ARN (for assuming a role)
# AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME
# AWS_ROLE_SESSION_NAME=octopos-session

# ============================================================================
# AWS Bedrock Configuration
# ============================================================================

# Nova Model IDs (these are placeholders - use actual model IDs from AWS)
BEDROCK_MODEL_NOVA_LITE=amazon.nova-lite-v1:0
BEDROCK_MODEL_NOVA_PRO=amazon.nova-pro-v1:0
BEDROCK_MODEL_NOVA_ACT=amazon.nova-act-v1:0
BEDROCK_MODEL_NOVA_SONIC=amazon.nova-sonic-v1:0

# Model for embeddings
BEDROCK_MODEL_EMBEDDING=amazon.titan-embed-text-v2:0

# Guardrails
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ============================================================================
# Agent Configuration
# ============================================================================

# Agent Identity
OCTO_AGENT_NAME=octoOS
OCTO_AGENT_PERSONA=friendly  # Options: friendly, professional, technical
OCTO_AGENT_LANGUAGE=tr       # Default language code

# User Information
OCTO_USER_NAME=
OCTO_USER_TIMEZONE=Europe/Istanbul
OCTO_WORKSPACE_PATH=~/octopos-workspace

# ============================================================================
# Vector Database (LanceDB)
# ============================================================================

LANCEDB_PATH=./data/lancedb
LANCEDB_TABLE_PRIMITIVES=primitives
LANCEDB_TABLE_MEMORY=memory

# ============================================================================
# Logging
# ============================================================================

LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_DESTINATION=stdout  # Options: stdout, file, cloudwatch
LOG_FORMAT=json  # Options: json, text

# File logging (only used if LOG_DESTINATION=file)
LOG_FILE_PATH=./logs/octopos.log
LOG_FILE_MAX_BYTES=10485760  # 10MB default
LOG_FILE_BACKUP_COUNT=5

# CloudWatch (only used if LOG_DESTINATION=cloudwatch)
CLOUDWATCH_LOG_GROUP=/octopos/agents
CLOUDWATCH_LOG_STREAM=default

# Distributed tracing
LOG_ENABLE_CORRELATION_ID=true
LOG_CORRELATION_ID_HEADER=x-correlation-id

# Sensitive Data Masking
LOG_MASK_SENSITIVE_DATA=true  # Enable/disable sensitive data masking in logs
LOG_MASK_CHARACTER=*          # Character used for masking (default: *)
# LOG_MASK_PATTERNS=          # Comma-separated custom regex patterns to mask (optional)

# ============================================================================
# Task Queue (SQLite for local, DynamoDB for cloud)
# ============================================================================

TASK_DB_PATH=./data/tasks.db
TASK_DB_TYPE=sqlite  # Options: sqlite, dynamodb

# DynamoDB settings (only used if TASK_DB_TYPE=dynamodb)
DYNAMODB_TABLE_TASKS=octopos-tasks
DYNAMODB_TABLE_SCHEDULE=octopos-schedule

# ============================================================================
# Interface Gateways
# ============================================================================

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_WEBHOOK_URL=

# Slack Bot (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# WhatsApp Business API (optional)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_SECRET=

# ============================================================================
# Security & Sandbox
# ============================================================================

# Docker settings
DOCKER_REGISTRY=
DOCKER_NETWORK=octopos-sandbox
DOCKER_CPU_LIMIT=1.0
DOCKER_MEMORY_LIMIT=512m

# Approval settings
REQUIRE_APPROVAL_FOR_CODE=true
REQUIRE_APPROVAL_FOR_DELETIONS=true
AUTO_APPROVE_SAFE_OPERATIONS=false

# ============================================================================
# Web Search & Intelligence
# ============================================================================

# Brave Search API Key (Required for high-quality web search)
BRAVE_API_KEY=your_brave_api_key_here

# DuckDuckGo fallback settings
DDG_SAFE_SEARCH=moderate  # strict, moderate, off
DDG_REGION=wt-wt          # See ddg docs for region codes

# ============================================================================
# Feature Flags (Optional Components)
# ============================================================================

# Set to true to enable optional features
# All features are disabled by default for minimal deployment

# Bot Interfaces
OCTOPOS_FEATURE_SLACK=false
OCTOPOS_FEATURE_WHATSAPP=false
OCTOPOS_FEATURE_TELEGRAM=false

# AI/ML Features
OCTOPOS_FEATURE_NOVA_ACT=false      # Browser automation
OCTOPOS_FEATURE_NOVA_SONIC=false    # Voice interface

# ============================================================================
# Development/Debug
# ============================================================================

# Set to true to skip AWS calls (for testing)
MOCK_AWS=false

# Debug mode
DEBUG=false

# Test mode (uses ephemeral resources)
TEST_MODE=false
